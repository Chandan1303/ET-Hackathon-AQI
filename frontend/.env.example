# Google Maps API Key
# Get your API key from: https://console.cloud.google.com/google/maps-apis
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# World Air Quality Index API (WAQI/AQICN)
# Get free API key from: https://aqicn.org/data-platform/token/
# Note: 'demo' key works for testing but has rate limits
VITE_AQICN_API_KEY=your_aqicn_api_key_here

# OpenAQ API Key (Optional - API works without key but with limits)
# Register at: https://openaq.org/
VITE_OPENAQ_API_KEY=your_openaq_api_key_here

# OpenWeather Air Pollution API
# Get free API key from: https://openweathermap.org/api
VITE_OPENWEATHER_API_KEY=your_openweather_api_key_here
